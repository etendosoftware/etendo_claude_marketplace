{
  "operation": "create_sales_order",
  "direction": "sales",
  "version": "26Q1",
  "tabIds": {
    "order": "186",
    "orderLine": "187"
  },
  "windowId": "143",
  "tableId": "259",
  "steps": [
    {
      "seq": 1,
      "description": "Resolve customer details (address, priceList, paymentTerms)",
      "type": "lookup",
      "method": "GET",
      "endpoint": "/etendo/org.openbravo.service.datasource/BusinessPartner",
      "queryParams": {
        "_where": "id='{{customerId}}'",
        "_startRow": 0,
        "_endRow": 1
      },
      "capture": {
        "partnerAddressId": "response.data[0].invoicingAddress",
        "priceListId":      "response.data[0].priceList",
        "paymentTermsId":   "response.data[0].paymentTerms",
        "paymentMethodId":  "response.data[0].paymentMethod",
        "currency":         "response.data[0].currency"
      }
    },
    {
      "seq": 2,
      "description": "Resolve product price + tax + UOM from price list",
      "type": "lookup",
      "method": "GET",
      "endpoint": "/etendo/org.openbravo.service.datasource/ProductByPriceAndWarehouse",
      "repeat": "per_line",
      "queryParams": {
        "_operationType": "fetch",
        "_startRow": 0,
        "_endRow": 1,
        "_selectorDefinitionId": "2E64F551C7C4470C80C29DBA24B34A5F",
        "targetProperty": "product",
        "columnName": "M_Product_ID",
        "inpmPricelistId": "{{priceListId}}",
        "inpmWarehouseId": "{{tenant.warehouse}}",
        "_where": "product.id='{{line.productId}}'"
      },
      "capture": {
        "line.unitPrice": "response.data[0].price",
        "line.uom":       "response.data[0].uOM",
        "line.tax":       "response.data[0].tax"
      }
    },
    {
      "seq": 3,
      "description": "Create Order header",
      "type": "write",
      "method": "POST",
      "endpoint": "/etendo/org.openbravo.service.datasource/Order?windowId=143&tabId=186&moduleId=0&_operationType=update&_noActiveFilter=true&sendOriginalIDBack=true",
      "payload": {
        "operationType": "add",
        "data": {
          "organization":          "{{tenant.organization}}",
          "client":                "{{tenant.client}}",
          "transactionDocument":   "{{tenant.salesOrderDocType}}",
          "orderDate":             "{{date}}",
          "scheduledDeliveryDate": "{{date}}",
          "accountingDate":        "{{date}}",
          "businessPartner":       "{{customerId}}",
          "partnerAddress":        "{{partnerAddressId}}",
          "invoiceAddress":        "{{partnerAddressId}}",
          "priceList":             "{{priceListId}}",
          "paymentTerms":          "{{paymentTermsId}}",
          "paymentMethod":         "{{paymentMethodId}}",
          "currency":              "{{currency}}",
          "warehouse":             "{{tenant.warehouse}}",
          "userContact":           "{{tenant.userContactId}}",
          "documentStatus":        "DR",
          "documentAction":        "CO",
          "salesTransaction":      true,
          "invoiceTerms":          "D",
          "deliveryMethod":        "P",
          "deliveryTerms":         "A",
          "freightCostRule":       "I",
          "priority":              "5",
          "formOfPayment":         "P",
          "posted":                "N",
          "active":                true,
          "ORDERTYPE":             "SO",
          "DOCBASETYPE":           "SOO"
        }
      },
      "capture": {
        "orderId":       "response.data[0].id",
        "documentNo":   "response.data[0].documentNo",
        "docTypeId":    "response.data[0].transactionDocument"
      }
    },
    {
      "seq": 4,
      "description": "Create OrderLine",
      "type": "write",
      "method": "POST",
      "endpoint": "/etendo/org.openbravo.service.datasource/OrderLine?windowId=143&tabId=187&moduleId=0&_operationType=update&_noActiveFilter=true&sendOriginalIDBack=true",
      "repeat": "per_line",
      "payload": {
        "operationType": "add",
        "data": {
          "salesOrder":            "{{orderId}}",
          "lineNo":                "{{10 * lineIndex}}",
          "organization":          "{{tenant.organization}}",
          "client":                "{{tenant.client}}",
          "currency":              "{{currency}}",
          "warehouse":             "{{tenant.warehouse}}",
          "businessPartner":       "{{customerId}}",
          "partnerAddress":        "{{partnerAddressId}}",
          "orderDate":             "{{date}}",
          "scheduledDeliveryDate": "{{date}}",
          "product":               "{{line.productId}}",
          "orderedQuantity":       "{{line.quantity}}",
          "operativeQuantity":     "{{line.quantity}}",
          "uOM":                   "{{line.uom}}",
          "operativeUOM":          "{{line.uom}}",
          "unitPrice":             "{{line.unitPrice}}",
          "listPrice":             "{{line.unitPrice}}",
          "standardPrice":         "{{line.unitPrice}}",
          "lineNetAmount":         "{{line.quantity * line.unitPrice}}",
          "taxableAmount":         "{{line.quantity * line.unitPrice}}",
          "tax":                   "{{line.tax}}",
          "active":                true,
          "DOCBASETYPE":           "SOO"
        }
      },
      "capture": {
        "line.orderLineId": "response.data[0].id"
      }
    },
    {
      "seq": 5,
      "description": "Complete Order (FormInitializationComponent CO)",
      "type": "process",
      "method": "POST",
      "endpoint": "/etendo/org.openbravo.client.kernel?MODE=EDIT&TAB_ID=186&PARENT_ID=null&ROW_ID={{orderId}}&_action=org.openbravo.client.application.window.FormInitializationComponent",
      "contentType": "application/x-www-form-urlencoded",
      "payload": {
        "inpcOrderId":            "{{orderId}}",
        "C_Order_ID":             "{{orderId}}",
        "inpadClientId":          "{{tenant.client}}",
        "inpadOrgId":             "{{tenant.organization}}",
        "inpcDoctypetargetId":    "{{docTypeId}}",
        "inpcDoctypeId":          "{{docTypeId}}",
        "inpdocumentno":          "{{documentNo}}",
        "inpdateordered":         "{{date|DD-MM-YYYY}}",
        "inpdatepromised":        "{{date|DD-MM-YYYY}}",
        "inpdateacct":            "{{date|DD-MM-YYYY}}",
        "inpcBpartnerId":         "{{customerId}}",
        "inpcBpartnerLocationId": "{{partnerAddressId}}",
        "inpbilltoId":            "{{partnerAddressId}}",
        "inpmPricelistId":        "{{priceListId}}",
        "inpcPaymenttermId":      "{{paymentTermsId}}",
        "inpfinPaymentmethodId":  "{{paymentMethodId}}",
        "inpcCurrencyId":         "{{currency}}",
        "inpmWarehouseId":        "{{tenant.warehouse}}",
        "inpdocaction":           "CO",
        "inpdocstatus":           "DR",
        "inpissotrx":             "Y",
        "inpprocessed":           "N",
        "inpposted":              "N",
        "inpinvoicerule":         "D",
        "inppaymentrule":         "P",
        "inpdeliveryrule":        "A",
        "inpdeliveryviarule":     "P",
        "inpfreightcostrule":     "I",
        "inppriorityrule":        "5",
        "inpisdiscountprinted":   "N",
        "inpTabId":               "186",
        "inpwindowId":            "143",
        "inpTableId":             "259",
        "inpkeyColumnId":         "C_Order_ID",
        "keyProperty":            "id",
        "ORDERTYPE":              "SO",
        "DOCBASETYPE":            "SOO",
        "PromotionsDefined":      "N"
      },
      "verify": "GET /etendo/org.openbravo.service.datasource/Order?_where=id='{{orderId}}' → documentStatus == 'CO'"
    }
  ]
}
