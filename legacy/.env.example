# ===========================================
# FYSO - Environment Variables
# ===========================================
# Copiar este archivo a .env y completar los valores
# NUNCA commitear .env al repositorio

# ===========================================
# DATABASE (Local PostgreSQL)
# ===========================================
DATABASE_URL="postgresql://postgres:syspass@localhost:5432/postgres"
DIRECT_URL="postgresql://postgres:syspass@localhost:5432/postgres"
DATABASE_SSL="disable"

# ===========================================
# APP CONFIG
# ===========================================
NODE_ENV="development"
PORT="3001"

# ===========================================
# OAuth 2.1 / JWT (Produccion)
# ===========================================
# RS256 keypair para firmar/verificar JWT tokens.
# En desarrollo se generan claves efimeras automaticamente.
# En produccion DEBEN configurarse para persistir entre reinicios.
#
# Generar con: bash scripts/generate-jwt-keys.sh

# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ===========================================
# URLs PUBLICAS (Produccion)
# ===========================================
# URL base del servidor API (sin trailing slash)
# Se usa para OAuth metadata (.well-known) y redirect validation
# Local: http://localhost:3001
# Produccion: https://app.fyso.dev
API_BASE_URL="http://localhost:3001"

# URL del frontend (para OAuth redirects)
# Local: http://localhost:3000
# Produccion: https://app.fyso.dev
FRONTEND_URL="http://localhost:3000"

# ===========================================
# MCP SERVER
# ===========================================
# URL base del servidor MCP
# Local: http://localhost:3002/mcp
# Produccion: https://app.fyso.dev/mcp
MCP_SERVER_URL="http://localhost:3002/mcp"

# URL del API para que el MCP server se comunique con el API
# Local: http://localhost:3001/api
# Produccion: https://app.fyso.dev/api
FYSO_API_URL="http://localhost:3001/api"

# ===========================================
# AI GENERATION (Opcional)
# ===========================================
# OpenAI API Key para generacion de entidades y UI
# OPENAI_API_KEY="sk-proj-..."
